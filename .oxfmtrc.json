{
  "printWidth": 80,
  "arrowParens": "avoid",
  "embeddedLanguageFormatting": "auto",
  "jsxSingleQuote": true,
  "proseWrap": "always",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "sortImports": {
    "internalPattern": ["#"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["**/node_modules/**/*"],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
